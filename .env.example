# Copy this file to `.env` and fill in your real SMTP settings.
# Docker Compose will automatically read `.env`.

# Allow login with any real email address and map it into the local demo university.
# Keep `false` if you want to allow only domains that exist in the `universities` table.
AUTH_ALLOW_ANY_EMAIL_DOMAIN=true

# Auth code behavior
EMAIL_CODE_TTL_SEC=600
EMAIL_CODE_RESEND_INTERVAL_SEC=60

# SMTP provider settings
# Mail.ru example:
SMTP_HOST=smtp.mail.ru
SMTP_PORT=465
SMTP_USE_SSL=true
SMTP_USE_TLS=false

# Yandex example:
# SMTP_HOST=smtp.yandex.ru
# SMTP_PORT=465
# SMTP_USE_SSL=true
# SMTP_USE_TLS=false

# Gmail example:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USE_SSL=false
# SMTP_USE_TLS=true

# Your real mailbox credentials
SMTP_USERNAME=your-mailbox@example.com
SMTP_PASSWORD=PASTE_YOUR_MAIL_APP_PASSWORD_HERE
SMTP_FROM_EMAIL=your-mailbox@example.com
SMTP_FROM_NAME=dormex
SMTP_TIMEOUT_SEC=10
